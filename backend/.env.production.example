# ===== Barval Block Factory — PRODUCTION .env =====
# cPanel par yeh values bharo, file ka naam .env rakho (server par).

APP_NAME="Barval Block Factory"
APP_ENV=production
APP_KEY=                       # khali — server par: php artisan key:generate
APP_DEBUG=false
APP_URL=https://baryal.pk
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=error

# ----- MySQL (cPanel "MySQL Databases" se banao, yahan paste karo) -----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpaneluser_barval      # cPanel jo naam dega
DB_USERNAME=cpaneluser_barval
DB_PASSWORD=                       # DB user ka password

# Single domain — SPA aur API ek hi origin par, isliye CORS/stateful ki zarurat nahi
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=baryal.pk

CACHE_STORE=database
QUEUE_CONNECTION=database

FRONTEND_URL=https://baryal.pk

# Mail (baad me set kar sakte ho — abhi log/null theek hai)
MAIL_MAILER=log
